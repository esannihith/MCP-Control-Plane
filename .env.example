# HTTP listener
PORT=8720
CP_HOST=127.0.0.1

# SQLite database file
CP_DB_PATH=./data/control-plane.db

# Externally reachable base URL (used for OAuth metadata/callbacks in later parts)
CP_PUBLIC_URL=http://localhost:8720

# Vault master key for encrypting upstream tokens (generate: npm run key -- master)
# CP_MASTER_KEY=
