# ============ Required ============

# Externally reachable base URL — baked into OAuth metadata, Google redirect
# URIs, and vendor callbacks. Exactly the public origin, no trailing slash.
CP_PUBLIC_URL=http://localhost:8720

# Vault master key encrypting all upstream tokens (generate: npm run key -- master).
# Losing it makes stored tokens unrecoverable.
CP_MASTER_KEY=

# Google OAuth client for user sign-in (console.cloud.google.com → Credentials →
# OAuth client, type "Web application"; authorized redirect URI:
#   <CP_PUBLIC_URL>/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============ Infrastructure (defaults usually fine) ============

# HTTP listener. Railway injects PORT; the Dockerfile sets CP_HOST=0.0.0.0.
PORT=8720
CP_HOST=127.0.0.1

# SQLite database file. Dockerfile sets /data/control-plane.db (mount a volume).
CP_DB_PATH=./data/control-plane.db

# ============ Optional ============

# How often the server checks for catalog changes to broadcast tools/list_changed (ms).
# CP_REGISTRY_POLL_MS=5000
