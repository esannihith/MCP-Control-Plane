# HTTP listener
PORT=8720
CP_HOST=127.0.0.1

# SQLite database file
CP_DB_PATH=./data/control-plane.db

# Externally reachable base URL (used for OAuth metadata/callbacks in later parts)
CP_PUBLIC_URL=http://localhost:8720

# Vault master key for encrypting upstream tokens (generate: npm run key -- master)
# CP_MASTER_KEY=

# Owner password: used on the legacy dashboard and OAuth consent screen.
# Applied at startup only if none is set yet (fresh deploys); otherwise
# manage it with: npm run owner -- set-password
# CP_OWNER_PASSWORD=

# SaaS sign-in (Google OAuth client from console.cloud.google.com;
# authorized redirect URI: <CP_PUBLIC_URL>/auth/google/callback)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# The Google account that adopts pre-SaaS single-tenant data on first sign-in
# CP_OWNER_EMAIL=
